---
import type { ImageMetadata } from 'astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('aktuality');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const { post } = Astro.props;
const { Content } = await render(post);

const datum = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
const datumKratce = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric' });

// Štítek s termínem u akcí a změn provozu (oznámení ho nemá)
const TYPY: Record<string, { nazev: string; badge: string }> = {
  'zmena-provozu': { nazev: 'Změna provozu', badge: 'badge-zmena' },
  akce: { nazev: 'Akce', badge: 'badge-akce' },
};
const typ = TYPY[post.data.typ];
const rozsah =
  post.data.od && post.data.do
    ? post.data.od.valueOf() === post.data.do.valueOf()
      ? datumKratce.format(post.data.od)
      : `${datumKratce.format(post.data.od)} – ${datumKratce.format(post.data.do)}`
    : undefined;

// Obrázek příspěvku: v CMS se ukládá cesta, tady ji dohledáme podle názvu souboru
const obrazky = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/aktuality/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true },
);
const nazevSouboru = post.data.obrazek?.split('/').pop();
const obrazek = nazevSouboru
  ? Object.entries(obrazky).find(([cesta]) => cesta.endsWith(`/${nazevSouboru}`))?.[1].default
  : undefined;
---

<Layout title={post.data.title}>
  <article class="section">
    <div class="container">
      <p><a href={`${base}/aktuality/`}>← Zpět na aktuality</a></p>
      <time class="muted" datetime={post.data.date.toISOString()}>{datum.format(post.data.date)}</time>
      {typ && rozsah && (
        <span class:list={['badge', typ.badge]} style="margin-left: 0.7rem;">{typ.nazev} · {rozsah}</span>
      )}
      <h1>{post.data.title}</h1>
      {obrazek && (
        <Image
          src={obrazek}
          alt={post.data.title}
          widths={[480, 800]}
          sizes="(max-width: 800px) 100vw, 800px"
          style="border-radius: var(--radius); margin-bottom: 1.5rem; max-width: 44rem;"
        />
      )}
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>
