---
import Layout from '../layouts/Layout.astro';
import kurzy from '../data/kurzy.json';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

// Každý kurz dostane barvu podle pořadí (--kurz-1 … --kurz-4 v global.css),
// stejná barva se používá na kartě i v rozvrhu
const barva = (i: number) => `--kurz-color: var(--kurz-${(i % 4) + 1})`;

// Týdenní rozvrh: kurzy rozdělené do dnů podle pole `rozvrh` v kurzy.json
const DNY = ['pondělí', 'úterý', 'středa', 'čtvrtek', 'pátek', 'sobota', 'neděle'];
const tyden = DNY.map((den) => ({
  den,
  lekce: kurzy.kurzy
    .flatMap((kurz, i) =>
      kurz.rozvrh
        .filter((r) => r.den === den)
        .map((r) => ({ nazev: kurz.nazev, cas: r.cas, barva: barva(i) })),
    )
    .sort((a, b) => a.cas.localeCompare(b.cas)),
}));
---

<Layout title="Kurzy" description="Výcvikové kurzy ZKO Nupaky – štěňata, začátečníci, pokročilí, sportovky i pachové práce.">
  <section class="section">
    <div class="container">
      <h1>Naše výcvikové kurzy</h1>
      <p class="lead">{kurzy.uvod}</p>

      <h2 class="section-title" style="margin-top: 2.5rem;">Nabídka kurzů</h2>
      <div class="grid grid-2">
        {kurzy.kurzy.map((kurz, i) => (
          <article class="card kurz-card" style={barva(i)}>
            <h3>{kurz.nazev}</h3>
            <p class="muted">{kurz.popis}</p>
            <span class="badge">{kurz.termin}</span>
          </article>
        ))}
      </div>

      <h2 class="section-title" style="margin-top: 3rem;">Týdenní rozvrh</h2>
      <div class="schedule">
        {tyden.map(({ den, lekce }) => (
          <div class={`schedule-day${lekce.length ? '' : ' is-empty'}`}>
            <div class="schedule-day-name">{den}</div>
            {lekce.map((l) => (
              <div class="lesson" style={l.barva}>
                <strong>{l.nazev}</strong>
                {l.cas && <span class="cas">od {l.cas}</span>}
              </div>
            ))}
          </div>
        ))}
      </div>

      <div class="grid grid-2" style="margin-top: 2.5rem;">
        <div class="card">
          <h3>Cena</h3>
          <p style="font-size: 1.4rem; font-weight: 700; margin-bottom: 0.3rem;">{kurzy.cena}</p>
          <p class="muted">{kurzy.individualni}</p>
        </div>
        <div class="card">
          <h3>Podmínky účasti</h3>
          <ul style="margin: 0; padding-left: 1.2rem;">
            {kurzy.podminky.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Přihlášení do kurzu</h2>
      <p class="muted">{kurzy.prihlaseni}</p>
      <a class="btn" href={`${base}/kontakty/`}>Všechny kontakty</a>
    </div>
  </section>
</Layout>
