---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import kurzy from '../data/kurzy.json';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

// Změny provozu z aktualit: ukazují se jen ty, které ještě platí
// a začínají nejpozději za 6 týdnů
const dnes = new Date();
const horizont = new Date(dnes);
horizont.setDate(horizont.getDate() + 42);
const konecDne = (d: Date) => new Date(d.getFullYear(), d.getMonth(), d.getDate(), 23, 59, 59);
const iso = (d: Date) => d.toISOString().slice(0, 10);
const datumKratce = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric' });

const zmeny = (await getCollection('aktuality'))
  .flatMap((post) =>
    post.data.zmenaProvozu ? [{ id: post.id, title: post.data.title, ...post.data.zmenaProvozu }] : [],
  )
  .filter((z) => konecDne(z.do) >= dnes && z.od <= horizont)
  .sort((a, b) => a.od.valueOf() - b.od.valueOf());

// Každý kurz dostane barvu podle pořadí (--kurz-1 … --kurz-4 v global.css),
// stejná barva se používá na kartě i v rozvrhu
const barva = (i: number) => `--kurz-color: var(--kurz-${(i % 4) + 1})`;

// Týdenní rozvrh: kurzy rozdělené do dnů podle pole `rozvrh` v kurzy.json
const DNY = ['pondělí', 'úterý', 'středa', 'čtvrtek', 'pátek', 'sobota', 'neděle'];
const tyden = DNY.map((den) => ({
  den,
  lekce: kurzy.kurzy
    .flatMap((kurz, i) =>
      kurz.rozvrh
        .filter((r) => r.den === den)
        .map((r) => ({ nazev: kurz.nazev, cas: r.cas, barva: barva(i) })),
    )
    .sort((a, b) => a.cas.localeCompare(b.cas)),
}));
---

<Layout title="Kurzy" description="Výcvikové kurzy ZKO Nupaky – štěňata, začátečníci, pokročilí, sportovky i pachové práce.">
  <section class="section">
    <div class="container">
      <h1>Naše výcvikové kurzy</h1>
      <p class="lead">{kurzy.uvod}</p>

      {zmeny.map((z) => (
        <aside class="notice" data-od={iso(z.od)} data-do={iso(z.do)}>
          <span class="badge badge-zmena">Změna provozu</span>
          <p>
            <strong>{z.title}</strong>
            <span class="muted"> · {datumKratce.format(z.od)} – {datumKratce.format(z.do)}</span>
            · <a href={`${base}/aktuality/${z.id}/`}>více informací</a>
          </p>
        </aside>
      ))}

      <h2 class="section-title" style="margin-top: 2.5rem;">Nabídka kurzů</h2>
      <div class="grid grid-2">
        {kurzy.kurzy.map((kurz, i) => (
          <article class="card kurz-card" style={barva(i)}>
            <h3>{kurz.nazev}</h3>
            <p class="muted">{kurz.popis}</p>
            <span class="badge">{kurz.termin}</span>
          </article>
        ))}
      </div>

      <h2 class="section-title" style="margin-top: 3rem;">Týdenní rozvrh</h2>
      <div class="schedule">
        {tyden.map(({ den, lekce }) => (
          <div class={`schedule-day${lekce.length ? '' : ' is-empty'}`}>
            <div class="schedule-day-name">{den}</div>
            {lekce.map((l) => (
              <div class="lesson" style={l.barva}>
                <strong>{l.nazev}</strong>
                {l.cas && <span class="cas">od {l.cas}</span>}
              </div>
            ))}
          </div>
        ))}
      </div>

      <div class="grid grid-2" style="margin-top: 2.5rem;">
        <div class="card">
          <h3>Cena</h3>
          <p style="font-size: 1.4rem; font-weight: 700; margin-bottom: 0.3rem;">{kurzy.cena}</p>
          <p class="muted">{kurzy.individualni}</p>
        </div>
        <div class="card">
          <h3>Podmínky účasti</h3>
          <ul style="margin: 0; padding-left: 1.2rem;">
            {kurzy.podminky.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Přihlášení do kurzu</h2>
      <p class="muted">{kurzy.prihlaseni}</p>
      <a class="btn" href={`${base}/kontakty/`}>Všechny kontakty</a>
    </div>
  </section>

  <script>
    // Pojistka mezi nasazeními: skryje oznámení, které mezitím vypršelo
    // nebo je dál než 6 týdnů dopředu
    const dnes = new Date();
    const horizont = new Date(dnes);
    horizont.setDate(horizont.getDate() + 42);
    document.querySelectorAll<HTMLElement>('.notice[data-od]').forEach((el) => {
      const od = new Date(`${el.dataset.od}T00:00:00`);
      const konec = new Date(`${el.dataset.do}T23:59:59`);
      el.hidden = konec < dnes || od > horizont;
    });
  </script>
</Layout>
